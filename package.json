{
  "name": "quantum-budget-optimizer",
  "version": "1.0.0",
  "description": "A quantum-walk-inspired shopping budget optimizer with AI recommendations",
  "type": "module",
  "main": "server/index.js",
  "scripts": {
    "dev:server": "node --import tsx/esm ./server/index.ts",
    "dev:client": "vite",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "build:server": "tsc --outDir dist/server --rootDir .",
    "build:client": "vite build",
    "build": "npm run build:client && npm run build:server",
    "start": "node dist/server/server/index.js",
    "preview": "vite preview"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "axios": "^1.6.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.0.0",
    "vite": "^4.3.0",
    "typescript": "^5.0.0",
    "tsx": "^3.12.0",
    "tailwindcss": "^3.3.0",
    "postcss": "^8.4.24",
    "autoprefixer": "^10.4.14",
    "concurrently": "^8.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/express": "^4.17.17",
    "@types/node": "^20.0.0"
  }
}
